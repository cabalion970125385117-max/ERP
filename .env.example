# ============================================================
# ATCA-ERP v1.0 — Environment Configuration
# Copy to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

NODE_ENV=production
PORT=3000

# LAN fixed IP of this server (IIS binding / Node direct)
HOST=192.168.1.10

# SQL Server — LAN fixed IP
DB_HOST=192.168.1.10
DB_PORT=1433
DB_NAME=ATCA_ERP_DB
DB_USER=atca_app
DB_PASS=CHANGE_ME_STRONG_PASSWORD

# Session secret — min 32 random characters
SESSION_SECRET=CHANGE_ME_TO_64_RANDOM_CHARS_ATCA_ERP_2026

# Internal SMTP for alert emails (optional)
SMTP_HOST=192.168.1.5
SMTP_PORT=25
SMTP_FROM=atca-erp@atc-aviation.local
ALERT_EMAIL_QA=qa.manager@atc-aviation.local
